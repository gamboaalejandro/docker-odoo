<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Visualización en Movimientos de Stock para Operarios (Solo Lectura) -->
    <record id="view_move_tree_inherit_tags" model="ir.ui.view">
        <field name="name">stock.move.list.inherit.tags</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <!-- Mostramos las etiquetas heredadas del product.product -->
                <field name="storage_tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Lineas detalladas de un Picking -->
    <record id="view_stock_move_line_detailed_operation_tree_inherit_tags" model="ir.ui.view">
        <field name="name">stock.move.line.operations.list.inherit.tags</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="product_id" invisible="1"/>
                <field name="product_id.storage_tag_ids" string="Etiquetas" widget="many2many_tags" options="{'color_field': 'color'}" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
