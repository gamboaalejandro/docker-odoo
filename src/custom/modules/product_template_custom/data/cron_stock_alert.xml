<odoo>
    <data noupdate="1">
        <record id="ir_cron_check_critical_stock" model="ir.cron">
            <field name="name">Inventario: Verificar Stock Crítico</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_critical_stock()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>