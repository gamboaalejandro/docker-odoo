<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Standalone form view for hr.payroll.test -->
    <record id="view_hr_payroll_test_form" model="ir.ui.view">
        <field name="name">hr.payroll.test.form</field>
        <field name="model">hr.payroll.test</field>
        <field name="arch" type="xml">
            <form string="Nómina Simulada">
                <header>
                    <button name="action_compute_sheet" type="object" string="Calcular Beneficios" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Referencia..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="contract_id" domain="[('employee_id', '=', employee_id)]"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Beneficios LOTTT" name="lottt_benefit_lines">
                            <field name="benefit_line_ids" readonly="1">
                                <list string="Líneas de Beneficios" editable="bottom">
                                    <field name="rule_id"/>
                                    <field name="benefit_type"/>
                                    <field name="amount" sum="Total Beneficios"/>
                                    <field name="note"/>
                                </list>
                            </field>
                            <group>
                                <field name="total_benefits" readonly="1" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Standalone tree view for hr.payroll.test -->
    <record id="view_hr_payroll_test_tree" model="ir.ui.view">
        <field name="name">hr.payroll.test.tree</field>
        <field name="model">hr.payroll.test</field>
        <field name="arch" type="xml">
            <list string="Nóminas Simuladas">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="total_benefits"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_payroll_test" model="ir.actions.act_window">
        <field name="name">Simulación de Nóminas</field>
        <field name="res_model">hr.payroll.test</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu placed under Employees application since Enterprise Payroll is not required -->
    <!-- Assuming hr.menu_hr_root is present -->
    <menuitem id="menu_hr_payroll_test"
              name="Nóminas Simuladas"
              parent="hr.menu_hr_employee_payroll"
              action="action_hr_payroll_test"
              sequence="15"/>
</odoo>
