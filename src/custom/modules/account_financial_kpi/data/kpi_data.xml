<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 1. Liquidez -->
        <record id="financial_kpi_liquidity" model="account.financial.kpi">
            <field name="name">Liquidez Corriente</field>
            <field name="sequence">1</field>
            <field name="formula">(asset_current + asset_cash) / ((liability_current * -1) if liability_current else 1)</field>
            <field name="evaluation_direction">higher_is_better</field>
            <field name="threshold_warning">1.5</field>
            <field name="threshold_critical">1.0</field>
        </record>

        <!-- 2. Prueba Ácida -->
        <record id="financial_kpi_acid_test" model="account.financial.kpi">
            <field name="name">Prueba Ácida</field>
            <field name="sequence">2</field>
            <field name="formula">(asset_current + asset_cash - get_balance('asset_inventory')) / ((liability_current * -1) if liability_current else 1)</field>
            <field name="evaluation_direction">higher_is_better</field>
            <field name="threshold_warning">1.0</field>
            <field name="threshold_critical">0.8</field>
        </record>

        <!-- 3. Rentabilidad sobre Activos (ROA) -->
        <record id="financial_kpi_roa" model="account.financial.kpi">
            <field name="name">ROA (Rent. Activos %)</field>
            <field name="sequence">3</field>
            <field name="formula">((income * -1) - expense - expense_direct_cost) / ((asset_current + asset_non_current + asset_fixed) if (asset_current + asset_non_current + asset_fixed) > 0 else 1) * 100</field>
            <field name="evaluation_direction">higher_is_better</field>
            <field name="threshold_warning">5.0</field>
            <field name="threshold_critical">0.0</field>
        </record>

        <!-- 4. Periodo Medio de Cobro (PMC) en Días -->
        <record id="financial_kpi_pmc" model="account.financial.kpi">
            <field name="name">Días de Cuentas por Cobrar (PMC)</field>
            <field name="sequence">4</field>
            <field name="formula">(asset_receivable) / ((income * -1) if income else 1) * 365</field>
            <field name="evaluation_direction">lower_is_better</field>
            <field name="threshold_warning">30.0</field>
            <field name="threshold_critical">60.0</field>
        </record>
    </data>
</odoo>
